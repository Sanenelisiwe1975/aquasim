# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=aquasim
POSTGRES_PASSWORD=aquasim_secret
POSTGRES_DB=aquasim

# Full async URL used by the engine and API (must match credentials above)
DATABASE_URL=postgresql+asyncpg://aquasim:aquasim_secret@localhost:5432/aquasim

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ────────────────────────────────────────────────────────────────────
# Use localhost:29092 for local dev; kafka:9092 inside Docker Compose
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# ── Engine mode ─────────────────────────────────────────────────────────────
# live     — generates synthetic GBM market data in real-time
# backtest — replays data/backtest_data.csv (run seed_backtest_data.py first)
MODE=live

# ── Migrations ──────────────────────────────────────────────────────────────
# Path to the migrations/ directory containing alembic.ini.
# Override in Docker (default works for local dev).
# MIGRATIONS_DIR=/app/migrations

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
